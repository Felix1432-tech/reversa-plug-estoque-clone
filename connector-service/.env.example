# Database (Supabase Postgres)
DATABASE_URL=postgresql+asyncpg://postgres:<password>@<host>:5432/postgres

# Encryption key for distributor credentials (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Backblaze B2 (S3-compatible)
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=product-photos
B2_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com

# Google Drive (L'Aquila connector)
GOOGLE_SERVICE_ACCOUNT_JSON=

# App
APP_ENV=development
LOG_LEVEL=INFO
